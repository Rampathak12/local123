{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "sh gradlew clean bootJar -x test"
  },
  "deploy": {
    "startCommand": "java -jar build/libs/productjpa-0.0.1-SNAPSHOT.jar --spring.profiles.active=railway",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
